    "version": "0.2.0",
    "configurations": [
        {
            "name": "NuxtShopMobile (Android / default device)",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define",
                "API_BASE_URL=http://localhost:4000"
            ]
        },
        {
            "name": "NuxtShopMobile (macOS)",
            "request": "launch",
            "type": "dart",
            "deviceId": "macos",
            "toolArgs": [
                "--dart-define",
                "API_BASE_URL=http://localhost:4000"
            ]
        },
        {
            "name": "NuxtShopMobile (iOS Simulator)",
            "request": "launch",
            "type": "dart",
            "toolArgs": [
                "--dart-define",
                "API_BASE_URL=http://localhost:4000"
            ]
        },
        {
            "name": "NuxtShopMobile (profile mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "NuxtShopMobile (release mode)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        }
    ]
}
